metadata:
  labels:
    app: app
  name: app
  namespace: ckad
spec:
  replicas: 1
  selector:
    matchLabels:
      app: app
  strategy: {}
  template:
    metadata:
      labels:
        app: app
    spec:
      containers:
      - image: nginx
        name: nginx
        env:
        - name: DB_USER
          value: admin
        - name: DB_PASS
          value: Secret123!
        ports:
        - containerPort: 80
        resources: {}
