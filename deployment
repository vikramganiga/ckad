#sample deployments v1
apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: web-app
    version: v1
  name: web-appv1
spec:
  replicas: 1
  selector:
    matchLabels:
      app: web-app
      version: v1
  strategy: {}
  template:
    metadata:
      labels:
        app: web-app
        version: v1
    spec:
      containers:
      - image: traefik
        name: traefik
        ports:
        - containerPort: 80
        resources: {}
status: {}

