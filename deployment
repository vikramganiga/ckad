#Create Canary Deployment with Manual Traffic Split

#deployment 
#create deployment does not support lables
kubectl create deployment web-app -n ckad --image=nginx --port=80 --dry-run=client -o yaml > web-app.yaml

#edit deployment yaml to add lables 
# error correction while defining labels : not =  sign to be used

apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: webapp
    version: v2
  name: web-app
  namespace: ckad
spec:
  replicas: 3
  selector:
    matchLabels:
      app: webapp
      version: v2
  strategy: {}
  template:
    metadata:
      labels:
        app: webapp
        version: v2
    spec:
      containers:
      - image: nginx
        name: nginx
        ports:
        - containerPort: 80
        resources: {}
status: {}

#service -
kubectl create service clusterip web-service -n ckad --tcp=80:80 --dry-run=client -o yaml > webserive.yaml

#edit add labels

apiVersion: v1
kind: Service
metadata:
  labels:
    app: web-service
  name: web-service
  namespace: ckad
spec:
  ports:
  - name: deploymentport
    port: 80
    protocol: TCP
    targetPort: 80
  selector:
    app: webapp
  type: ClusterIP
status:
  loadBalancer: {}

