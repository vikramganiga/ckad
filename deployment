#Deployment with readiness
kubectl create deployment app --image=nginx --port=80 -n ckad --dry-run=client -o yaml > deployment-app.yaml
# update deployment-app.yaml
# (example)

apiVersion: apps/v1
kind: Deployment
metadata:
  name: broken-app
spec:
  replicas: 2
  selector:
    matchLabels:
      app: myapp
  template:
    metadata:
      labels:
        app: myapp
    spec:
      containers:
        - name: web
          image: nginx
          readinessProbe:
            httpGet:
             path: /ready
             port: 8080
          initialDelaySeconds: 5
          periodSeconds: 10

kubectl create -f deployment-app.yaml
kubectl rollout status deployment app

